# === Banco (Railway injeta automaticamente ao ligar o plugin PostgreSQL) ===
DATABASE_URL=postgresql://user:pass@host:5432/railway

# === Auth ===
JWT_SECRET=troque-por-uma-string-aleatoria-longa
ADMIN_ORIGIN=https://seu-admin.exemplo.com

# === GitHub (dispara o deploy) ===
GITHUB_TOKEN=github_pat_xxx   # fine-grained PAT, permissao Contents: Read & Write
GITHUB_OWNER=seu-usuario
GITHUB_REPO=site                 # repo do SITE publico (nao o do cms)
GITHUB_BRANCH=main
CONTENT_PATH=public/content.json # o site React le daqui (pasta public do Vite)

# === Imagens (commitadas no repo do site) ===
IMAGE_DIR=public/images          # pasta no repo do site onde as imagens vao
IMAGE_PUBLIC_PREFIX=/images      # prefixo da URL publica servida pelo site

# === Seed (apague depois de criar o admin) ===
SEED_ADMIN_USER=fernando
SEED_ADMIN_PASS=SenhaForte@123
